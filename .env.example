# 実AIは最終受け入れ試験だけで使用してください（API利用料金が発生します）。
OPENAI_API_KEY=
GEMINI_API_KEY=
ALLOW_REAL_AI=1
DATABASE_PATH=./data/ai-werewolf.db
AI_PROVIDER=real
# 以下2項目はCLI実行時の一括指定用。Web試合はキャラクターごとの保存設定を使用します。
LLM_PROVIDER=openai
GEMINI_MODEL=gemini-2.5-pro
TTS_PROVIDER=voicevox
VOICEVOX_URL=http://127.0.0.1:50021
AIVISSPEECH_URL=http://127.0.0.1:10101
